  "keyFeatures": [
    "Role-based access control with granular module-level permissions",
    "Student lifecycle management from inquiry to graduation",
    "Comprehensive fee management with challans, installments, and arrears tracking",
    "Attendance tracking for both students and staff",
    "Examination management with marks, results, and report cards",
    "HR & payroll with deductions, allowances, and advance salary management",
    "Hostel management with room allocation and inventory",
    "Finance module with income, expense, and closing balance tracking",
    "School inventory tracking with maintenance and expense logs",
    "Front office with inquiries, visitor management, and complaint handling",
    "Cloudinary integration for photo and document uploads",
    "Docker Compose deployment with MySQL database"
  ],
